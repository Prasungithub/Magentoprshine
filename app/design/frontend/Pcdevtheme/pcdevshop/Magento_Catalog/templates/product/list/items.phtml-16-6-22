    <script>
        require([
            "jquery", 'jquery/ui'
        ], function ($) {

            $( ".associated-product-qty-plus-<?php echo $type; ?>").click(function() {
                var inputValAssociated = $(this).parent().find('.associated-product-qty-input-<?php echo $type; ?>').val();  

                if(inputValAssociated !== '0'){
                    var inputValAssociatedAdd = parseInt(inputValAssociated) + 1;
                }else{
                    var inputValAssociatedAdd = 1;
                }  

                var product_id      = $(this).attr("product_id");
                var section         = $(this).attr("section");
                //$(this).parent().find('.associated-product-qty-input').val(inputValAssociatedAdd);
                var url = "<?= $block->escapeUrl($qtyupdateBlock->getAjaxAddActionUrl()) ?>";
                jQuery("body").loader("show");
                $.ajax({
                    type: "POST",
                    url: url,
                    data: {mode :"add" ,product_id : product_id, qty : 1 }, // serializes the form's elements.
                    success: function (data)
                    {
                        jQuery("body").loader("hide");
                        if(data.status_code ==1){                          
                            qtyBoxCounterUpdate(product_id,inputValAssociatedAdd,section);
                        }                  
                    }
                });  
            });
            
            $(".associated-product-qty-minus-<?php echo $type; ?>").click(function() {
                var inputValAssociated = parseInt($(this).parent().find('.associated-product-qty-input-<?php echo $type; ?>').val());              
                if(inputValAssociated > 0 ){
                    var inputValAssociatedAdd = inputValAssociated - 1;
                }else{
                    var inputValAssociatedAdd = 0;
                }
                //$(this).parent().find('.associated-product-qty-input').val(inputValAssociatedAdd);
                var product_id      = $(this).attr("product_id");
                var section         = $(this).attr("section");

                var url = "<?= $block->escapeUrl($qtyupdateBlock->getAjaxUpdateActionUrl()) ?>";
                jQuery("body").loader("show");
                $.ajax({
                    type: "POST",
                    url: url,
                    data: {mode :"update", product_id : product_id, qty : inputValAssociatedAdd}, // serializes the form's elements.
                    success: function (data)
                    {
                        jQuery("body").loader("hide");
                        if(data.status_code ==1){
                            qtyBoxCounterUpdate(product_id,inputValAssociatedAdd,section);
                        }

                    }
                });  
            });

            $(".associated-product-qty-input-<?php echo $type; ?>").keyup(function() {
                var key = event.keyCode || event.charCode;

                if( key == 8 || key == 46 ){
                    return false;
                }            
                var inputValAssociated = parseInt($(this).val());     

                if(inputValAssociated > 0 ){
                    var inputValAssociatedAdd = inputValAssociated;
                    
                }else{
                    var inputValAssociatedAdd = 0;
                }

                var product_id      = $(this).attr("product_id"); 
                var section         = $(this).attr("section");
                var url = "<?= $block->escapeUrl($qtyupdateBlock->getAjaxUpdateActionUrl()) ?>";
                jQuery("body").loader("show");
                $.ajax({
                    type: "POST",
                    url: url,
                    data: {mode :"update", product_id : product_id, qty : inputValAssociatedAdd}, // serializes the form's elements.
                    success: function (data)
                    {
                        jQuery("body").loader("hide");
                        if(data.status_code ==1){
                            qtyBoxCounterUpdate(product_id,inputValAssociatedAdd,section);

                        }
                    }
                });  
            });

            $(document).on("blur", '.associated-product-qty-input-<?php echo $type; ?>', function() { 
                var inputValAssociated = $(this).val(); 
                if(!inputValAssociated){
                    $(this).val(0); 
                }
            });


            $(".qty-box-counter-<?php echo $type; ?>").click(function() {
                $(this).fadeOut();    
                $(this).next().fadeIn();
                $(this).next().delay(8000).fadeOut();           
                //$(this).stop(true,true).delay(8000).fadeOut();           
                $(this).delay(8000).fadeIn();     
                var has_product = $(this).hasClass("has-product");

                if(!has_product){
                    var inputQty = $(this).next().find('.associated-product-qty-input-<?php echo $type; ?>');
                    var inputValAssociated = inputQty.val(); 

                    if(inputValAssociated !== '0'){
                        var inputValAssociatedAdd = parseInt(inputValAssociated) + 1;
                    }else{
                        var inputValAssociatedAdd = 1;
                    }

                    var inputValAssociatedAdd = 1;
                    var product_id      = inputQty.attr("product_id");
                     var section         = $(this).attr("section");

                    //inputQty.val(inputValAssociatedAdd);
                    var url = "<?= $block->escapeUrl($qtyupdateBlock->getAjaxAddActionUrl()) ?>";
                    jQuery("body").loader("show");
                    $.ajax({
                        type: "POST",
                        url: url,
                        data: {mode :"add" ,product_id : product_id, qty : 1}, // serializes the form's elements.
                        success: function (data)
                        {
                            jQuery("body").loader("hide");
                            if(data.status_code ==1){                     
                                qtyBoxCounterUpdate(product_id,inputValAssociatedAdd,section);
                            }               
                        }

                    });    
                }
            });

           function qtyBoxCounterUpdate(product_id,inputValAssociatedAdd,section){
                var qty_box_counter_Id = "#qty_box_counter_"+product_id+section; 
                $("#quantity_"+product_id+section).val(inputValAssociatedAdd); 
                
                
                
                var qty_box_details_counter_Id = "#qty_box_counter_details_"+product_id+section; 
                if(qty_box_details_counter_Id){
                     var addHtml ='<span class="btn-text"><?= $escaper->escapeHtml(__("Add to Cart")) ?></span>';
                    if(inputValAssociatedAdd > 0){
                       
                        addHtml +='<span class="btn-count">'+inputValAssociatedAdd+'</span>';
                        $(qty_box_details_counter_Id).html(addHtml); 
                        $(qty_box_details_counter_Id).addClass("has-product"); 
                    }else{
                        addHtml +='<span class="btn-count">+</span>';
                        $(qty_box_details_counter_Id).html(addHtml); 
                        $(qty_box_details_counter_Id).removeClass("has-product");
                    }
                }
                
                
                
                
                
                if(inputValAssociatedAdd > 0){
                    $(qty_box_counter_Id).text(inputValAssociatedAdd); 
                    $(qty_box_counter_Id).addClass("has-product"); 
                }else{
                    $(qty_box_counter_Id).text("+"); 
                    $(qty_box_counter_Id).removeClass("has-product");
                }

                if(inputValAssociatedAdd == 1){
                    $("#associated_product_qty_minus_id_"+product_id+section).addClass("delete-qty-minus"); 
                }else{
                    $("#associated_product_qty_minus_id_"+product_id+section).removeClass("delete-qty-minus");
                }
            }

        });
    </script>  
    <!--qty Box end -->   