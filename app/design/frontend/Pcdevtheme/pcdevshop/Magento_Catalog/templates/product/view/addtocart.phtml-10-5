/** @var $block \Magento\Catalog\Block\Product\View */
?>
<?php $_product = $block->getProduct(); ?>
<?php $buttonTitle = __('Add to Cart'); ?>
<?php if ($_product->isSaleable()) :?>

<div class="stock available" title="Availability" style="display:none">
            <span>In stock</span>
</div>

<?php
$IdDoProduto = $_product->getId();

$product_id = $IdDoProduto ;

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
 $cart = $objectManager->get('\Magento\Checkout\Model\Session'); 

// retrieve quote items collection
$itemsCollection = $cart->getQuote()->getItemsCollection();

// get array of all items what can be display directly
$itemsVisible = $cart->getQuote()->getAllVisibleItems();

// retrieve quote items array
 $items = $cart->getQuote()->getAllItems();

foreach($items as $item) {
	
	 if($IdDoProduto == $item->getProduct_id()){
            $cart_qty = $item->getQty();
			$item_id = $item->getId();
	 }         
  }
 ?>


<div class="box-tocart">
    <div class="fieldset">
        <?php if ($block->shouldRenderQuantity()) :?>
        <div class="field qty" style="display:none" >
            <label class="label" for="qty"><span><?= $block->escapeHtml(__('Qty')) ?></span></label>
            <div class="control qty-box">
			<a href="javascript:void(0)" class="qtyminus"><i class="fa fa-minus"></i></a>
                <input type="text" name="qty" id="qty<?php echo $_product->getId(); ?>" maxlength="4" min="1" value="1" title="<?php /* @escapeNotVerified */ echo __('Qty') ?>" class="input-text qty cart-item-qty" data-validate="<?= $block->escapeHtmlAttr(json_encode($block->getQuantityValidators())) ?>"/>
		    <a href="javascript:void(0)" class="qtyplus"><i class="fa fa-plus"></i></a>
            </div>
			
        </div>
        <?php endif; ?>
		<div class="associated-product-qty-box-wrapper" style="width: 170px;">
        <div class="actions qty-box-counter-cart" <?php if(isset($item_id)) { ?> style="display:none" <?php } else { ?> style="display:block" <?php } ?>>
            <button type="submit"
                    title="<?= $block->escapeHtmlAttr($buttonTitle) ?>"
                    class="action primary tocart addd"
                    id="product-addtocart-button" disabled>
                <span><?= $block->escapeHtml($buttonTitle) ?></span>
            </button>
            <?= $block->getChildHtml('', true) ?>
        </div>
					
						
						<div class="associated-product-qty" <?php if(isset($item_id)) { ?> style="display:block" <?php } else { ?> style="display:none" <?php } ?>>
							<span id="associated_product_qty_minus_id_<?php echo $product_id ; ?>" class="associated-product-qty-minus <?php if(isset($cart_qty) && $cart_qty==1) { ?> delete-qty-minus <?php } ?> "> -</span>
							<span>
								<input name="quantity[<?php echo $product_id ; ?>]" id="quantity_<?php echo $product_id ; ?>" type="number" class="associated-product-qty-input" value="<?php if(isset($cart_qty)) { echo $cart_qty ; } else { echo 1; } ?>" max="25" datastock="98" >
							</span>
							<span class="associated-product-qty-plus-add">+ </span>
						</div>
					</div>
		</div>
    </div>						

<?php endif; ?>


<script type="text/x-magento-init">
    {
        "#product_addtocart_form": {
            "Magento_Catalog/js/validate-product": {}
        }
    }
</script>


<script type="text/javascript">
	
 
	require(['jquery', 'jquery/ui'], function($){
		$(document).ready( function() {
 
			setTimeout(function () {
					$(".qty-box-counter-cart").click(function(){
				 //alert("ddd");
					$('button.action.addd').hide();
					$('.associated-product-qty').show();
					
				});
				
				$(".associated-product-qty-plus-add").click(function(){
				$('button.action.addd').trigger("click");
				
				var inputValAssociated = $(".associated-product-qty-input").val();                            
                var inputValAssociatedAdd = parseInt(inputValAssociated) + 1;
                $(".associated-product-qty-input").val(inputValAssociatedAdd);
                //$(".update_qty").val(inputValAssociatedAdd);				
				$(".associated-product-qty-minus").removeClass("delete-qty-minus");				
				});
				
				$(".associated-product-qty-minus").click(function(){
				//$('button.action.addd').trigger("click");
				
				var inputValAssociated = $(".associated-product-qty-input").val();                            
                var inputValAssociatedAdd = parseInt(inputValAssociated) - 1;
                $(".associated-product-qty-input").val(inputValAssociatedAdd);
				//$(".update_qty").val(inputValAssociatedAdd);
				
				
				if(inputValAssociated == 2){
						$(".associated-product-qty-minus").addClass("delete-qty-minus"); 
					}else{
						$(".associated-product-qty-minus").removeClass("delete-qty-minus");
					}
					
				if(inputValAssociated == 1){
					$('button.action.addd').show();
					$('.associated-product-qty').hide();
				}
				
				});
				
				
			}, 100);
		});
	});
 
</script>


