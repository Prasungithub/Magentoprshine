?>
<?php
$_product = $this->getProduct();
?>
<?php
$helper = $this->helper("Citytech\Customization\Helper\Customization");
$lifestyles  = $_product->getLifestyle();
$lifestylesArr = explode(",",$lifestyles);
?>
<?php if($lifestyles){ ?>
<?php if(count($lifestylesArr) >0 ) { ?>
    <ul  class="lifestylesImg-wrapper">
    <?php foreach($lifestylesArr as $lifestyleOptionId) { ?>
        <?php $lifestylesImg= $helper->getLifestyleImgPath($lifestyleOptionId); ?>
            <?php if($lifestylesImg && isset($lifestylesImg['image'])) { ?>
                <?php 
                    $attr = $_product->getResource()->getAttribute('lifestyle');
                    $optionText ="";
                    if ($attr->usesSource()) {
                        $optionText = $attr->getSource()->getOptionText($lifestyleOptionId);
                    }
                ?> 
                <li class="lifestylesImg">
                    <img src="<?= $helper->getMediaUrl()."amasty/shopby/option_images/".$lifestylesImg['image']; ?>" title="<?= $optionText; ?>" />
                </li>
            <?php } ?>
    <?php } ?>
    </ul>
<?php } ?>
<?php } ?>
<div class="details-description-outer">
<div class="details-description-inner">
<div class="<?php if($_product->getIngredients()){ echo "details-description-left"; }else{ echo "details-description"; } ?>">
<div class="details-description-left-content">
<p><?php echo $_product->getData('did_you_know'); ?></p>
<p class="sdesc-mobile"><?php echo $this->helper('Magento\Catalog\Helper\Output')->productAttribute($_product, $_product->getShort_description(), 'short_description') ?></p>
<?php echo $this->helper('Magento\Catalog\Helper\Output')->productAttribute($_product, $_product->getDescription(), 'description') ?>
<div class="details-description-ingredients">
<h2><?= $escaper->escapeHtml(__('Ingredients')) ?></h2>
<?php echo $_product->getIngredients(); ?>
</div>
<div class="details-description-allergen details-description-ingredients ali-mobile">
<h2><?= $escaper->escapeHtml(__('Allergen')) ?></h2>
<?php echo $_product->getAllergen(); ?>
</div>
</div>
</div>

<div class="details-description-right">
<?php
$productNutritionAttributes=$_product->getAttributes();
$attributeSetId = $_product->getAttributeSetId();
$nutritionGroupId = $helper->__getAttributeGroupId($attributeSetId,'Nutrition Facts');
if($nutritionGroupId != 0){
?>
<div class="details-description-right-content">
<div class="details-description-nutrition">
<h2><?= $escaper->escapeHtml(__('Nutrition Facts')) ?></h2>
<span><?= $escaper->escapeHtml(__('Serving size')) ?> <?php echo $_product->getData('nutrnfacts_serving_size'); ?></span>
<p class="highlight"><?= $escaper->escapeHtml(__('Amount per serving')) ?></p>

<div class="nutrition-outer">
	<div class="nutrition-inner">
<?php
	foreach($productNutritionAttributes as $nutritionAttribute) {
		if($nutritionAttribute->isInGroup($attributeSetId, $nutritionGroupId)) {
			if($nutritionAttribute->getAttributeCode() == 'nutrnfacts_serving_size'){ continue; }
			if(trim($nutritionAttribute->getFrontend()->getValue($_product))){
?>
				<div class="nutrition-row">
					<span><?php echo $nutritionAttribute->getFrontendLabel(); ?></span>
					<span><?php echo $nutritionAttribute->getFrontend()->getValue($_product); ?></span>
				</div>
<?php
			}
	    }
	}
?>
	</div>
</div>

</div>
</div>
<?php
}
?>
<div class="details-description-storage details-description-ingredients storage-mobile">
<h2><?= $escaper->escapeHtml(__('Storage')) ?></h2>
<?php echo $_product->getStorage(); ?>
</div>
</div>

</div>
</div>


