<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
	<system>
        <section id="erpdataconfig" translate="label" sortOrder="170" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>ERP Data</label>
            <tab>citytechconfig</tab>
            <resource>Pcdev_Erpdata::erpdata_config</resource>
            <group id="erpdatagp" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="1">
                <label>ERP Data</label>			
                <field id="erpcustaccount" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>CustAccount</label>
					<comment>Enter CustAccount no. provided by ERP i.e. C01003920</comment>
                </field>	
                <field id="erpcompanyid" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>CompanyId</label>
					<comment>Enter CompanyId provided by ERP i.e. AE01</comment>
                </field>
                <field id="erpdataorigin" translate="label" type="text" sortOrder="3" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>DataOrigin</label>
					<comment>Enter DataOrigin provided by ERP i.e. ECom</comment>
                </field>
                <field id="erpdatagranttype" translate="label" type="text" sortOrder="4" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Grant Type</label>
					<comment>Enter Grant Type provided by ERP i.e. client_credXXXXXXXX</comment>
                </field>
                <field id="erpdataclientid" translate="label" type="text" sortOrder="5" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Client Id</label>
					<comment>Enter Client Id provided by ERP i.e. 37623XXX-XXXX-XXXX</comment>
                </field>
                <field id="erpdataclientsecret" translate="label" type="text" sortOrder="6" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Client Secret</label>
					<comment>Enter Client Secret provided by ERP i.e. PXTXX~XXXXXXX_XXX</comment>
                </field>	
                <field id="erpdataresource" translate="label" type="text" sortOrder="7" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Resource URL</label>
					<comment>Enter Resource URL provided by ERP i.e. https://dev2e55XXXXXXXXX.com</comment>
                </field>				
            </group>		
        </section>		
		
		
        <section id="swftboxconfig" translate="label" sortOrder="180" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Swftbox</label>
            <tab>citytechconfig</tab>
            <resource>Pcdev_Erpdata::swftbox_config</resource>
            <group id="swftboxgp" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="1">
                <label>Swftbox API Setting</label>
                <field id="swftboxapiendpointurl" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API ENDPOINT URL</label>
					<comment>Enter CustAccount no. provided by ERP i.e. https://testapi.carlee.co/api/</comment>
                </field>								
            </group>		
        </section>			
		
		
    </system>
</config>